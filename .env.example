# Copy this file to .env.local and fill in real values (.env.local is git-ignored).
# SMTP credentials for the "Get in Touch" lead form.

# Microsoft 365 custom-domain mailbox: smtp.office365.com
# Personal outlook.com mailbox:        smtp-mail.outlook.com
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=info@xpertshome.com
SMTP_PASS=your-mailbox-password-or-app-password

# Inbox that receives lead notifications (defaults to SMTP_USER if omitted).
LEAD_TO=info@xpertshome.com
